# Минимальная конфигурация для OpenAI-совместимого chat-completions endpoint.
# Скопируйте этот файл в .env или экспортируйте переменные вручную.

LLM_API_KEY=your_api_key_here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_PATH=/chat/completions
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1400
LLM_TIMEOUT=120
LLM_RETRIES=2
LLM_RETRY_SLEEP=4
LLM_APP_NAME=teenbook-wikidata-generator
# Дополнительные заголовки, если конкретный провайдер их требует:
# LLM_EXTRA_HEADERS_JSON={"HTTP-Referer":"https://example.com","X-Title":"TeenBook"}
